{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "api/wsgi.py": {
      "maxDuration": 30,
      "excludeFiles": "{venv/**,media/**,backups/**,dist/**,node_modules/**,__pycache__/**,*.sqlite3}"
    }
  },
  "routes": [
    {
      "src": "/\\.env(.*)",
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/\\.git/(.*)",
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/wp-(admin|login|content|includes)(.*)",
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/(phpmyadmin|vendor|server-status)(.*)",
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/(.*)",
      "dest": "api/wsgi.py"
    }
  ],
  "crons": [
    {
      "path": "/api/internal/cron/google-sheet-syncs/",
      "schedule": "0 8 * * *"
    }
  ]
}
