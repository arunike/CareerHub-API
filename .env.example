# CareerHub now uses explicit environment modes.
#
# Local development:
#   cp .env.development.example .env.development
#
# Production:
#   configure platform-managed environment variables
#   or copy .env.production.example to .env.production
#
# Django loads one file based on DJANGO_ENV:
#   development -> .env.development
#   production  -> .env.production
#   test        -> .env.test (optional)
#
# If DATABASE_URL is unset, Django falls back to the local SQLite file at api/db.sqlite3.
