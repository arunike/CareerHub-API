DEBUG=False
SECRET_KEY=replace-me-with-a-long-random-secret-key-at-least-50-characters
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com
DATABASE_URL=postgresql://careerhub:change-me@your-postgres-host:5432/careerhub?sslmode=require
DB_CONN_MAX_AGE=60
ENABLE_ADMIN=False
ALLOW_PUBLIC_SIGNUP=False
AUTO_LOGIN_AFTER_SIGNUP=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
# Optional if you are ready to enforce HSTS across subdomains / preload lists:
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Upload / import safety limits
MAX_DOCUMENT_UPLOAD_BYTES=10485760
MAX_LOGO_UPLOAD_BYTES=5242880
MAX_IMPORT_FILE_BYTES=5242880
MAX_IMPORT_ROWS=1000

# Local dev example:
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# DATABASE_URL=postgresql://careerhub:careerhub@localhost:5432/careerhub
# ENABLE_ADMIN=True
# ALLOW_PUBLIC_SIGNUP=True
# AUTO_LOGIN_AFTER_SIGNUP=True
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=0
#
# If DATABASE_URL is unset, Django falls back to the local SQLite file at api/db.sqlite3.
