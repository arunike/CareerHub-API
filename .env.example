# ============================================================
# CareerHub — Environment Variables
# Copy this file to .env and fill in values before running.
# NEVER commit the real .env to git.
# ============================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=replace-me-with-a-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Redis
# When running via Docker Compose, REDIS_HOST is overridden to
# "redis" (the service name) by docker-compose.yml.
# For local development without Docker, leave this as localhost.
REDIS_HOST=localhost
REDIS_PORT=6379
