# CareerHub now uses explicit environment modes.
#
# Local development:
#   cp .env.development.example .env.development
#
# Production:
#   configure platform-managed environment variables
#   or copy .env.production.example to .env.production
#
# Hosted deployments that need Blob-backed uploads should also set:
#   BLOB_READ_WRITE_TOKEN=<public logo Blob read/write token>
#   DOCUMENT_BLOB_READ_WRITE_TOKEN=<private document Blob read/write token>
#
# Private Google Sheets OAuth sync:
#   GOOGLE_OAUTH_CLIENT_ID=<google-oauth-web-client-id>
#   GOOGLE_OAUTH_CLIENT_SECRET=<google-oauth-web-client-secret>
#   GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=https://your-frontend.vercel.app/settings?tab=integrations
#
# Django loads one file based on DJANGO_ENV:
#   development -> .env.development
#   production  -> .env.production
#   test        -> .env.test (optional)
#
# If DATABASE_URL is unset, Django falls back to the local SQLite file at api/db.sqlite3.
