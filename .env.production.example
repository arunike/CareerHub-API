DJANGO_ENV=production
SECRET_KEY=replace-me-with-a-long-random-secret-key-at-least-50-characters
DEBUG=False
ALLOWED_HOSTS=your-api-project.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend-project.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-project.vercel.app
PUBLIC_FRONTEND_BASE_URL=https://your-frontend-project.vercel.app
DATABASE_URL=postgresql://careerhub:change-me@your-postgres-host:5432/careerhub?sslmode=require
BLOB_READ_WRITE_TOKEN=replace-with-your-public-logo-vercel-blob-read-write-token
DOCUMENT_BLOB_READ_WRITE_TOKEN=replace-with-your-private-document-vercel-blob-read-write-token
DB_CONN_MAX_AGE=60
JWT_SIGNING_KEY=replace-with-a-dedicated-jwt-signing-secret
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14

AI_PROVIDER_ENCRYPTION_KEY=replace-with-a-dedicated-32-byte-or-passphrase-secret
AI_PROVIDER_ALLOWED_HOSTS=api.anthropic.com,generativelanguage.googleapis.com,api.openai.com,openrouter.ai
AI_PROVIDER_REQUIRE_HTTPS=True
AI_PROVIDER_RESTRICT_PRIVATE_NETWORKS=True
AI_PROVIDER_REQUEST_TIMEOUT_SECONDS=30
DRF_AI_PROVIDER_RELAY_RATE=20/hour
CRON_SECRET=replace-with-a-random-secret-at-least-16-characters
ENABLE_ADMIN=False
ALLOW_PUBLIC_SIGNUP=True
AUTO_LOGIN_AFTER_SIGNUP=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True

MAX_DOCUMENT_UPLOAD_BYTES=4194304
MAX_LOGO_UPLOAD_BYTES=4194304
MAX_IMPORT_FILE_BYTES=5242880
MAX_IMPORT_ROWS=1000
