DJANGO_ENV=production
SECRET_KEY=replace-me-with-a-long-random-secret-key-at-least-50-characters
DEBUG=False
ALLOWED_HOSTS=api.your-domain.com
CORS_ALLOWED_ORIGINS=https://app.your-domain.com
CSRF_TRUSTED_ORIGINS=https://app.your-domain.com
DATABASE_URL=postgresql://careerhub:change-me@your-postgres-host:5432/careerhub?sslmode=require
DB_CONN_MAX_AGE=60
REDIS_HOST=your-redis-host
REDIS_PORT=6379
AI_PROVIDER_ENCRYPTION_KEY=replace-with-a-dedicated-32-byte-or-passphrase-secret
AI_PROVIDER_ALLOWED_HOSTS=generativelanguage.googleapis.com
AI_PROVIDER_REQUIRE_HTTPS=True
AI_PROVIDER_RESTRICT_PRIVATE_NETWORKS=True
AI_PROVIDER_REQUEST_TIMEOUT_SECONDS=30
DRF_AI_PROVIDER_RELAY_RATE=20/hour
ENABLE_ADMIN=False
ALLOW_PUBLIC_SIGNUP=True
AUTO_LOGIN_AFTER_SIGNUP=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
# Optional if every subdomain is permanently HTTPS:
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
MAX_DOCUMENT_UPLOAD_BYTES=10485760
MAX_LOGO_UPLOAD_BYTES=5242880
MAX_IMPORT_FILE_BYTES=5242880
MAX_IMPORT_ROWS=1000
