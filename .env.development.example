DJANGO_ENV=development
SECRET_KEY=django-insecure-local-dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql://careerhub:careerhub@localhost:5432/careerhub
DB_CONN_MAX_AGE=60
ENABLE_ADMIN=False
ALLOW_PUBLIC_SIGNUP=True
AUTO_LOGIN_AFTER_SIGNUP=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
MAX_DOCUMENT_UPLOAD_BYTES=10485760
MAX_LOGO_UPLOAD_BYTES=5242880
MAX_IMPORT_FILE_BYTES=5242880
MAX_IMPORT_ROWS=1000
REDIS_HOST=localhost
REDIS_PORT=6379
AI_PROVIDER_REQUIRE_HTTPS=False
AI_PROVIDER_RESTRICT_PRIVATE_NETWORKS=False
AI_PROVIDER_REQUEST_TIMEOUT_SECONDS=30

# Docker Compose local overrides
POSTGRES_DB=careerhub
POSTGRES_USER=careerhub
POSTGRES_PASSWORD=careerhub
POSTGRES_PORT=5432
API_PORT=8000
# Optional: override the container-internal DB URL used by docker compose services.
# DOCKER_DATABASE_URL=postgresql://careerhub:careerhub@postgres:5432/careerhub
DRF_AI_PROVIDER_RELAY_RATE=20/hour
